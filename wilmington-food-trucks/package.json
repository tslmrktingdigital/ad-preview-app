{
  "name": "wilmington-food-trucks",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "packages/*",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=packages/api\" \"npm run dev --workspace=packages/web\"",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:migrate": "npx prisma migrate dev --schema=packages/api/prisma/schema.prisma",
    "db:studio": "npx prisma studio --schema=packages/api/prisma/schema.prisma"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  }
}
